#!/bin/bash
#Generated by JetBrains Toolbox 3.4.3.81140 at 2026-05-22T15:36:04

declare -a intellij_args=()
declare -- wait=""

for o in "$@"; do
  if [[ "$o" = "--wait" || "$o" = "-w" ]]; then
    wait="-W"
    o="--wait"
  fi
  if [[ "$o" =~ " " ]]; then
    intellij_args+=("\"$o\"")
  else
    intellij_args+=("$o")
  fi
done

open -na "/Users/dean/Applications/PhpStorm.app/Contents/MacOS/phpstorm" $wait --args "${intellij_args[@]}"